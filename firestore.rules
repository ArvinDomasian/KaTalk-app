rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return signedIn() && request.auth.uid == userId;
    }

    function isAdmin() {
      return signedIn() &&
        exists(/databases/$(database)/documents/admins/$(request.auth.uid)) &&
        get(/databases/$(database)/documents/admins/$(request.auth.uid)).data.disabled != true;
    }

    function isNotBanned() {
      return signedIn() &&
        (!exists(/databases/$(database)/documents/userProfiles/$(request.auth.uid)) ||
          get(/databases/$(database)/documents/userProfiles/$(request.auth.uid)).data.moderation.isBanned != true);
    }

    function ownerCannotSelfModerate() {
      return !request.resource.data.diff(resource.data).affectedKeys().hasAny(['moderation', 'adminRole']);
    }

    function ownerCannotSelfVerify() {
      return !('verification' in request.resource.data) ||
        (resource.data.verification.status == 'verified' &&
          request.resource.data.verification.status == 'verified') ||
        (resource.data.verification.status != 'verified' &&
          request.resource.data.verification.status in ['not_started', 'manual_pending', 'fast_track_pending']);
    }

    function validReportCreate() {
      return signedIn() &&
        request.resource.data.reporterId == request.auth.uid &&
        request.resource.data.targetUserId is string &&
        request.resource.data.status == 'open';
    }

    function messageMatchParticipant(matchId) {
      return signedIn() &&
        request.auth.uid in get(/databases/$(database)/documents/liveMessageMatches/$(matchId)).data.participantIds;
    }

    match /admins/{adminId} {
      allow get: if isOwner(adminId) || isAdmin();
      allow list: if isAdmin();
      allow create, update, delete: if isAdmin();
    }

    match /reports/{reportId} {
      allow create: if validReportCreate();
      allow read, update, delete: if isAdmin();
    }

    match /userProfiles/{userId} {
      allow get: if isOwner(userId) || isAdmin();
      allow list: if isAdmin();
      allow create: if isAdmin() ||
        (isOwner(userId) &&
          request.resource.data.id == userId &&
          !('moderation' in request.resource.data) &&
          !('adminRole' in request.resource.data) &&
          (!('verification' in request.resource.data) ||
            request.resource.data.verification.status != 'verified'));
      allow update: if isAdmin() ||
        (isOwner(userId) &&
          request.resource.data.id == resource.data.id &&
          ownerCannotSelfModerate() &&
          ownerCannotSelfVerify());
      allow delete: if isAdmin();
    }

    match /liveProfiles/{userId} {
      allow read: if signedIn();
      allow create, update: if isOwner(userId) && isNotBanned();
      allow delete: if isOwner(userId) || isAdmin();
    }

    match /liveMessageMatchQueue/{userId} {
      allow read: if signedIn() && isNotBanned();
      allow create, update, delete: if isOwner(userId) && isNotBanned();
    }

    match /liveMessageMatches/{matchId} {
      allow create: if signedIn() &&
        isNotBanned() &&
        request.auth.uid in request.resource.data.participantIds;
      allow read, update: if isAdmin() ||
        (signedIn() && request.auth.uid in resource.data.participantIds && isNotBanned());
      allow delete: if isAdmin();

      match /messages/{messageId} {
        allow read, create: if messageMatchParticipant(matchId) && isNotBanned();
        allow update, delete: if isAdmin();
      }
    }

    match /liveVideoMatchQueue/{userId} {
      allow read: if signedIn() && isNotBanned();
      allow create, update, delete: if isOwner(userId) && isNotBanned();
    }

    match /liveVideoMatches/{matchId} {
      allow create: if signedIn() &&
        isNotBanned() &&
        request.auth.uid in request.resource.data.participantIds;
      allow read, update: if isAdmin() ||
        (signedIn() && request.auth.uid in resource.data.participantIds && isNotBanned());
      allow delete: if isAdmin();
    }

    match /liveBlocks/{blockId} {
      allow read: if isAdmin() ||
        (signedIn() &&
          (request.auth.uid == resource.data.blockerId || request.auth.uid == resource.data.blockedId));
      allow create: if signedIn() &&
        request.resource.data.blockerId == request.auth.uid &&
        isNotBanned();
      allow update, delete: if isAdmin();
    }

    match /profilePosts/{postId} {
      allow read: if signedIn();
      allow create: if signedIn() &&
        request.resource.data.profileId == request.auth.uid &&
        isNotBanned();
      allow update, delete: if isAdmin() ||
        (signedIn() && resource.data.profileId == request.auth.uid && isNotBanned());
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
