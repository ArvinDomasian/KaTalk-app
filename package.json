{
  "name": "katalk",
  "version": "0.1.0",
  "private": true,
  "main": "expo/AppEntry.js",
  "scripts": {
    "start": "expo start",
    "android": "expo start --android",
    "ios": "expo start --ios",
    "web": "expo start --web --offline",
    "build:android:apk": "eas build --platform android --profile preview",
    "build:android:aab": "eas build --platform android --profile production",
    "build:android:preview": "eas build --platform android --profile preview",
    "build:android:store": "eas build --platform android --profile production",
    "build:ios:store": "eas build --platform ios --profile production",
    "build:all:store": "eas build --platform all --profile production",
    "submit:android": "eas submit --platform android --profile production",
    "submit:ios": "eas submit --platform ios --profile production",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@expo/metro-runtime": "~4.0.1",
    "@expo/vector-icons": "~14.0.4",
    "@react-native-community/datetimepicker": "8.2.0",
    "expo": "~52.0.0",
    "expo-asset": "~11.0.5",
    "expo-audio": "~0.3.5",
    "expo-camera": "~16.0.0",
    "expo-constants": "~17.0.8",
    "expo-font": "~13.0.4",
    "expo-location": "~18.0.0",
    "expo-status-bar": "~2.0.0",
    "firebase": "^11.0.0",
    "react": "18.3.1",
    "react-dom": "18.3.1",
    "react-native": "0.76.9",
    "react-native-agora": "^4.5.0",
    "react-native-google-mobile-ads": "^16.4.0",
    "react-native-purchases": "^10.4.0",
    "react-native-safe-area-context": "4.12.0",
    "react-native-screens": "~4.4.0",
    "react-native-web": "~0.19.13"
  },
  "devDependencies": {
    "@types/react": "~18.3.12",
    "eas-cli": "^20.4.0",
    "typescript": "^5.3.3"
  }
}
